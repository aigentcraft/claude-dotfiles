{
  "autoUpdatesChannel": "latest",
  "effortLevel": "high",
  "model": "opus",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/claude-dotfiles/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/claude-dotfiles/.claude/hooks/pre-bash-git-push.sh"
          }
        ]
      }
    ]
  }
}
